{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cctv-backend-seod.onrender.com/api/:path*"
    },
    {
      "source": "/videos/:path*",
      "destination": "https://cctv-backend-seod.onrender.com/videos/:path*"
    },
    {
      "source": "/clips/:path*",
      "destination": "https://cctv-backend-seod.onrender.com/clips/:path*"
    },
    {
      "source": "/snapshots/:path*",
      "destination": "https://cctv-backend-seod.onrender.com/snapshots/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
